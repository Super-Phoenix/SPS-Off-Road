{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": { "@game/*": ["src/game/*"], "@shell/*": ["src/shell/*"], "@server/*": ["src/server/*"] }
  },
  "include": ["src", "tests", "data"]
}
